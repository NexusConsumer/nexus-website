    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.23",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.22.0",
