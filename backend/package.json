    "db:embed": "tsx scripts/embed-knowledge.ts",
    "db:delete-login-user": "tsx scripts/delete-login-user.ts",
    "domain:backfill": "tsx scripts/backfill-domain-model.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.14.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
