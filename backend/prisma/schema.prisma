// Nexus Backend — Prisma Schema
// PostgreSQL on Railway

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── ENUMS ─────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  AGENT
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum ChatStatus {
  OPEN
  PENDING_HUMAN
  RESOLVED
  CLOSED
}

enum ChatMode {
  AI
  HUMAN
}

enum MessageSender {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum MessageChannel {
  WEB
  WHATSAPP
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  WALLET
  COD
}

// ─── AUTH ─────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified Boolean      @default(false)
  fullName      String
  passwordHash  String?
  country       String       @default("IL")
  role          UserRole     @default(USER)
  emailUpdates  Boolean      @default(true)
  avatarUrl     String?
  provider      AuthProvider @default(EMAIL)
  googleId      String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastLoginAt   DateTime?

  refreshTokens RefreshToken[]
  chatSessions  ChatSession[]
  orders        Order[]

  @@index([email])
  @@index([googleId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model PasswordReset {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tokenHash])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  country      String   @default("IL")
  emailUpdates Boolean  @default(true)
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([tokenHash])
  @@index([email])
}

// ─── CHAT ─────────────────────────────────────────────────────────

model ChatSession {
  id              String     @id @default(cuid())
  userId          String?
  user            User?      @relation(fields: [userId], references: [id])
  visitorId       String
  status          ChatStatus @default(OPEN)
  mode            ChatMode   @default(AI)
  assignedAgentWa String?
  subject         String?
  waThreadId      String?
  metadata        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  messages ChatMessage[]

  @@index([visitorId])
  @@index([status])
  @@index([mode])
}

model ChatMessage {
  id          String         @id @default(cuid())
  sessionId   String
  session     ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      MessageSender
  channel     MessageChannel @default(WEB)
  text        String         @db.Text
  waMessageId String?
  status      String?
  createdAt   DateTime       @default(now())

  rating AiRating?

  @@index([sessionId])
  @@index([createdAt])
}

// ─── AI / KNOWLEDGE ───────────────────────────────────────────────

model AiConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model KnowledgeChunk {
  id        String                                @id @default(cuid())
  title     String
  content   String                                @db.Text
  source    String?
  language  String                                @default("he")
  isActive  Boolean                               @default(true)
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                              @default(now())
  updatedAt DateTime                              @updatedAt

  @@index([isActive])
}

model AiExample {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  category  String?
  language  String   @default("he")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([category])
}

model AiRating {
  id         String      @id @default(cuid())
  messageId  String      @unique
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  rating     Int
  feedback   String?     @db.Text
  correction String?     @db.Text
  ratedBy    String?
  createdAt  DateTime    @default(now())
}

// ─── ANALYTICS ────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  page      String
  referrer  String?
  userAgent String?
  ipAddress String?
  country   String?
  language  String?
  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
  @@index([page])
}

model VisitorEvent {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
}

model VisitorProfile {
  id             String   @id @default(cuid())
  visitorId      String   @unique
  firstSeen      DateTime @default(now())
  lastSeen       DateTime @updatedAt
  pageViewCount  Int      @default(0)
  chatCount      Int      @default(0)
  apolloData     Json?
  apolloEnriched Boolean  @default(false)

  @@index([visitorId])
  @@index([lastSeen])
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// ─── LEADS ─────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  email     String?
  fullName  String?
  company   String?
  phone     String?
  message   String?    @db.Text
  status    LeadStatus @default(NEW)
  source    String     @default("contact_sales")
  metadata  Json?
  apolloId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── ORDERS ────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  status          PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CARD)
  subtotalAmount  Int
  shippingAmount  Int           @default(0)
  taxAmount       Int           @default(0)
  totalAmount     Int
  currency        String        @default("ILS")
  providerName    String?
  providerOrderId String?
  providerData    Json?
  shippingAddress Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items         OrderItem[]
  paymentEvents PaymentEvent[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  quantity    Int
  unitPrice   Int
  totalPrice  Int

  @@index([orderId])
}

model PaymentEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Partner {
  id           String   @id @default(cuid())
  title        String
  thumbnailUrl String
  categories   String[]
  discount     String?
  description  String?
  websiteUrl   String?
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}
