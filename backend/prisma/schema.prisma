// Nexus Backend — Prisma Schema
// PostgreSQL on Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  AGENT
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum ChatStatus {
  OPEN
  PENDING_HUMAN
  RESOLVED
  CLOSED
}

enum ChatMode {
  AI
  HUMAN
}

enum MessageSender {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum MessageChannel {
  WEB
  WHATSAPP
  EMAIL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  WALLET
  COD
}

enum EventChannel {
  MARKETING
  PRODUCT
  WALLET
}

enum AccountType {
  B2B
  B2C
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── ACCOUNTS (B2B/B2C hierarchy) ─────────────────────────────────

model Account {
  id           String      @id @default(cuid())
  name         String
  type         AccountType @default(B2C)
  domain       String?
  plan         String?
  websiteUrl   String?
  businessDesc String?
  useCases     String[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  users        User[]

  @@index([domain])
}

// ─── ORGANIZATIONS ────────────────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  nameHe       String?
  logoUrl      String?
  primaryColor String?
  plan         String?
  isPremium    Boolean  @default(false)
  isPublished  Boolean  @default(false)
  websiteUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members OrganizationMember[]
  invites OrgInvite[]

  @@index([slug])
}

model OrgInvite {
  id        String    @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role      OrgRole   @default(MEMBER)
  token     String    @unique @default(cuid())
  createdBy String
  label     String?
  maxUses   Int?
  useCount  Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([orgId])
}

model OrganizationMember {
  id          String   @id @default(cuid())
  userId      String
  orgId       String
  role        OrgRole  @default(MEMBER)
  displayName String?
  avatarUrl   String?
  title       String?
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
}

// ─── AUTH ─────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified Boolean      @default(false)
  fullName      String
  passwordHash  String?
  country       String       @default("IL")
  role          UserRole     @default(USER)
  emailUpdates  Boolean      @default(true)
  avatarUrl     String?
  provider        AuthProvider @default(EMAIL)
  googleId        String?      @unique
  accountId       String?
  account         Account?     @relation(fields: [accountId], references: [id])
  phone           String?
  jobTitle        String?
  onboardingDone  Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lastLoginAt     DateTime?

  refreshTokens  RefreshToken[]
  chatSessions   ChatSession[]
  orders         Order[]
  orgMemberships OrganizationMember[]

  @@index([email])
  @@index([googleId])
  @@index([accountId])
}

model RefreshToken {
  id                   String    @id @default(cuid())
  tokenHash            String    @unique
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt            DateTime
  revokedAt            DateTime?
  // When this token is rotated, holds the hash of the replacement token so a
  // racing second request can follow the chain instead of triggering bulk-revoke.
  replacedByTokenHash  String?
  userAgent            String?
  ipAddress            String?
  createdAt            DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([replacedByTokenHash])
}

model PasswordReset {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tokenHash])
}

model PendingRegistration {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  fullName          String
  country           String   @default("IL")
  emailUpdates      Boolean  @default(true)
  tokenHash         String   @unique
  dashboardRedirect String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([tokenHash])
  @@index([email])
}

// ─── CHAT ─────────────────────────────────────────────────────────

model ChatSession {
  id                String     @id @default(cuid())
  userId            String?
  user              User?      @relation(fields: [userId], references: [id])
  visitorId         String
  status            ChatStatus @default(OPEN)
  mode              ChatMode   @default(AI)
  assignedAgentWa   String?
  assignedAgentName String?
  subject           String?
  waThreadId        String?
  whatsappGroupId   String?    // Green API group chatId for this session
  emailMessageId    String?    // Message-ID of first escalation email (for threading)
  outlookConversationId String? // Outlook conversationId for thread grouping
  outlookLastMessageId  String? // Graph message ID of latest email in thread
  modeLockUntil     DateTime?
  agentId           String?    // AI agent assigned to this session (SEO/Marketing/Sales)
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  messages ChatMessage[]

  @@index([visitorId])
  @@index([status])
  @@index([mode])
  @@index([agentId])
}

model ChatMessage {
  id          String         @id @default(cuid())
  sessionId   String
  session     ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      MessageSender
  channel     MessageChannel @default(WEB)
  text        String         @db.Text
  waMessageId String?
  status      String?
  aiMetadata  Json?          // chunks used, similarity scores, token usage
  mediaUrl    String?        // External URL or base64 data URL
  mediaType   String?        // "image" | "video" | "audio" | "document"
  fileName    String?        // Original filename for documents
  createdAt   DateTime       @default(now())

  rating AiRating?

  @@index([sessionId])
  @@index([createdAt])
}

// ─── AI / KNOWLEDGE ───────────────────────────────────────────────

model AiConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model KnowledgeChunk {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  source    String?
  language  String   @default("he")
  isActive  Boolean  @default(true)
  embedding Float[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AiExample {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  category  String?
  language  String   @default("he")
  isActive  Boolean  @default(true)
  embedding Float[]  // for similarity-matched retrieval
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([category])
}

model AiRating {
  id         String      @id @default(cuid())
  messageId  String      @unique
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  rating     Int
  feedback   String?     @db.Text
  correction String?     @db.Text
  ratedBy    String?
  createdAt  DateTime    @default(now())
}

model KnowledgeGap {
  id        String   @id @default(cuid())
  question  String   @db.Text
  bestScore Float
  chunkId   String?
  sessionId String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolved])
  @@index([createdAt])
}

// ─── ANALYTICS ────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  page      String
  referrer  String?
  userAgent String?
  ipAddress String?
  country   String?
  language  String?
  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
  @@index([page])
}

model VisitorEvent {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
}

model VisitorProfile {
  id             String   @id @default(cuid())
  visitorId      String   @unique
  firstSeen      DateTime @default(now())
  lastSeen       DateTime @updatedAt
  pageViewCount  Int      @default(0)
  pageViews      Int      @default(0)
  chatCount      Int      @default(0)
  apolloData     Json?
  apolloEnriched Boolean  @default(false)
  ip             String?
  city           String?
  country        String?
  device         String?
  browser        String?

  @@index([visitorId])
  @@index([lastSeen])
}

model EventLog {
  id          String       @id @default(cuid())
  anonymousId String?
  userId      String?
  accountId   String?
  eventName   String
  channel     EventChannel
  properties  Json
  context     Json
  sentAt      DateTime?
  receivedAt  DateTime     @default(now())

  @@index([anonymousId])
  @@index([userId])
  @@index([accountId])
  @@index([eventName, receivedAt])
  @@index([channel, receivedAt])
}

model IdentityMap {
  id          String   @id @default(cuid())
  anonymousId String
  userId      String
  mergeSource String
  mergedAt    DateTime @default(now())

  @@unique([anonymousId, userId])
  @@index([anonymousId])
  @@index([userId])
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// ─── LEADS ─────────────────────────────────────────────────────────

model Lead {
  id                  String     @id @default(cuid())
  email               String?
  fullName            String?
  company             String?
  phone               String?
  message             String?    @db.Text
  status              LeadStatus @default(NEW)
  source              String     @default("contact_sales")
  metadata            Json?
  apolloId            String?
  agentId             String?    // AI agent owning this lead (e.g. Sales agent)
  qualificationScore  Float?              // 0-100, set by lead-qualifier skill
  qualificationReason String?    @db.Text
  lastFollowUpAt      DateTime?
  nextFollowUpAt      DateTime?
  followUpCount       Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([agentId])
}

// ─── ORDERS ────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  status          PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CARD)
  subtotalAmount  Int
  shippingAmount  Int           @default(0)
  taxAmount       Int           @default(0)
  totalAmount     Int
  currency        String        @default("ILS")
  providerName    String?
  providerOrderId String?
  providerData    Json?
  shippingAddress Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items         OrderItem[]
  paymentEvents PaymentEvent[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  quantity    Int
  unitPrice   Int
  totalPrice  Int

  @@index([orderId])
}

model PaymentEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Partner {
  id           String   @id @default(cuid())
  title        String
  thumbnailUrl String
  categories   String[]
  discount     String?
  description  String?
  websiteUrl   String?
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

// ─── BLOG ──────────────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogArticle {
  id              String        @id @default(cuid())
  slug            String
  lang            String        // "en" | "he"
  status          ArticleStatus @default(DRAFT)
  title           String        @db.Text
  subtitle        String?       @db.Text
  excerpt         String?       @db.Text
  heroImage       String?
  metaTitle       String?
  metaDescription String?       @db.Text
  category        String?
  authorName      String?
  authorRole      String?
  authorAvatar    String?
  publishDate     DateTime?
  readTime        Int?
  sectionsJson    Json          // ArticleSection[]
  faqJson         Json?         // ArticleFAQ[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  @@unique([slug, lang])
  @@index([lang, status])
  @@index([status])
}

// ─── PAGE META OVERRIDES ───────────────────────────────────────────
//
// SEO meta overrides for any page on the site.
// The agent (Tier 1) writes here; the frontend useSEO hook reads these
// and applies them over hardcoded defaults — without requiring a new deploy.
//
// slug = full URL pathname: "/", "/he", "/benefits", "/he/payments", etc.
// lang = "en" | "he" (derived from slug prefix; kept for query convenience)

model PageMeta {
  id              String   @id @default(cuid())
  slug            String
  lang            String   @default("en")
  metaTitle       String?
  metaDescription String?  @db.Text
  ogImage         String?
  updatedBy       String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([slug, lang])
  @@index([slug])
  @@index([lang])
}

// ─── AGENT REQUESTS ────────────────────────────────────────────────

enum AgentAction {
  BLOG_PUBLISH
  BLOG_UPDATE_PUBLISHED
  BLOG_UNPUBLISH
}

enum AgentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model AgentRequest {
  id              String             @id @default(cuid())
  agentId         String?
  action          AgentAction
  payload         Json
  status          AgentRequestStatus @default(PENDING)
  result          Json?
  rejectionReason String?            @db.Text
  requestedAt     DateTime           @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  confidence      Float?             // 0.0 – 1.0 (agent confidence in this change)
  approvalMode    ApprovalMode?
  pageUrl         String?
  seoField        String?
  oldValue        String?            @db.Text
  newValue        String?            @db.Text

  @@index([agentId])
  @@index([status])
  @@index([requestedAt])
}

// ─── ORCHESTRATION ──────────────────────────────────────────────────

model WebhookLog {
  id          String   @id @default(cuid())
  externalId  String   @unique
  source      String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model MondayItem {
  id           String   @id @default(cuid())
  mondayItemId String   @unique
  boardId      String
  sessionId    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
}

model AiSuggestion {
  id          String   @id @default(cuid())
  sessionId   String
  suggestion  String   @db.Text
  sentToAgent Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([sessionId])
}

// ─── AGENT INFRASTRUCTURE ─────────────────────────────────────────
//
// Multi-agent OS shared infrastructure.
// Enables: autonomous scheduling, budget tracking, task prioritization,
// memory, and structured logging.

enum AgentType {
  SEO
  MARKETING
  SALES
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
  SKIPPED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
  FAILED
}

enum ApprovalMode {
  AUTO
  NOTIFY_24H
  REQUIRE_APPROVAL
  BLOCKED
}

model Agent {
  id           String    @id @default(cuid())
  slug         String    @unique       // "seo", "marketing", "sales"
  name         String                  // "SEO Agent"
  type         AgentType
  description  String?   @db.Text
  systemPrompt String?   @db.Text
  config       Json?                   // agent-specific settings
  integrations String[]                // e.g. ["gsc","ga4","trends"] or ["whatsapp","monday"]
  skills       String[]                // registered skill names
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  automations  AgentAutomation[]
  tasks        AgentTask[]
  logs         AgentLog[]
  budgets      TokenBudget[]

  @@index([slug])
  @@index([type])
  @@index([isActive])
}

model AgentAutomation {
  id          String           @id @default(cuid())
  agentId     String?
  agent       Agent?           @relation(fields: [agentId], references: [id])
  name        String           @unique
  description String?
  skill       String
  cronExpr    String
  status      AutomationStatus @default(ACTIVE)
  priority    Int              @default(5)
  timeoutSec  Int              @default(1800)
  config      Json?
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  runs AgentAutomationRun[]

  @@index([agentId])
  @@index([status])
  @@index([skill])
}

model AgentAutomationRun {
  id           String          @id @default(cuid())
  automationId String
  automation   AgentAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       RunStatus       @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  tokensUsed   Int?
  costUsd      Float?
  summary      String?         @db.Text
  errorMessage String?         @db.Text
  createdAt    DateTime        @default(now())

  @@index([automationId])
  @@index([status])
  @@index([createdAt])
}

model AgentLog {
  id         String   @id @default(cuid())
  agentId    String?
  agent      Agent?   @relation(fields: [agentId], references: [id])
  skill      String
  action     String
  details    Json?
  tokensUsed Int?
  costUsd    Float?
  durationMs Int?
  status     String   @default("success")
  errorMsg   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([agentId])
  @@index([skill])
  @@index([status])
  @@index([createdAt])
}

model AgentTask {
  id          String     @id @default(cuid())
  agentId     String?
  agent       Agent?     @relation(fields: [agentId], references: [id])
  title       String
  description String?    @db.Text
  skill       String?
  status      TaskStatus @default(PENDING)
  impact      Float      @default(5)
  confidence  Float      @default(5)
  ease        Float      @default(5)
  iceScore    Float      @default(5)
  payload     Json?
  result      Json?
  scheduledAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([iceScore])
  @@index([createdAt])
}

model TokenBudget {
  id         String   @id @default(cuid())
  agentId    String?
  agent      Agent?   @relation(fields: [agentId], references: [id])
  date       DateTime
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  budgetUsd  Float    @default(0.30)
  model      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, agentId])
  @@index([agentId])
  @@index([date])
}

// ─── GEO MONITORING ────────────────────────────────────────────────

model GeoPrompt {
  id        String        @id @default(cuid())
  text      String        @db.Text
  lang      String        @default("he")
  category  String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  snapshots GeoSnapshot[]

  @@index([active])
  @@index([lang])
}

model GeoSnapshot {
  id            String    @id @default(cuid())
  promptId      String
  prompt        GeoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  model         String
  mentioned     Boolean   @default(false)
  mentionCount  Int       @default(0)
  positionRatio Float?
  snippet       String?   @db.Text
  runAt         DateTime  @default(now())

  @@index([promptId])
  @@index([model])
  @@index([runAt])
}

model AgentMemory {
  id         String    @id @default(cuid())
  agentId    String?
  memoryType String
  key        String
  content    String    @db.Text
  embedding  Float[]
  metadata   Json?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([agentId])
  @@index([memoryType])
  @@index([key])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
