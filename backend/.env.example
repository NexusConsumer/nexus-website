# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nexus?schema=public"
MONGODB_URI="mongodb+srv://user:password@cluster.example.mongodb.net/?appName=YourApp"
MONGODB_DB="nexus_dev"

# ─── JWT ─────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET="generate-64-char-random-hex"
REFRESH_TOKEN_SECRET="generate-64-char-random-hex"

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxx"

# ─── App URLs ────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
DASHBOARD_URL="http://localhost:5174"
BACKEND_URL="https://api.nexus-payment.com"
NODE_ENV="development"
PORT="3001"
BUILD_ID="20260101-v1"
NIXPACKS_NODE_VERSION="22"

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-svcacct-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (SMTP / SendPulse) ────────────────────────────────
EMAIL_FROM="no-reply@yourdomain.com"
EMAIL_ASSET_BASE_URL="https://nexus-payment.com"
SMTP_HOST="smtp-pulse.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user@example.com"
SMTP_PASS="your-smtp-password"
SENDPULSE_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDPULSE_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Platform Admin Emails ───────────────────────────────────
# Comma-separated list of NEXUS platform admin emails.
# These receive voucher approval request notifications.
NEXUS_ADMIN_EMAILS="admin@yourdomain.com,admin2@yourdomain.com"

# ─── WhatsApp (Green API) ────────────────────────────────────
WHATSAPP_PROVIDER="green_api"
WHATSAPP_VERIFY_TOKEN="pick-any-random-string"
AGENT_WHATSAPP_NUMBER="972XXXXXXXXX"
GREEN_API_ID_INSTANCE="xxxxxxxxxx"
GREEN_API_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GREEN_API_URL="https://xxxx.api.greenapi.com"

# ─── Inbound Email ───────────────────────────────────────────
INBOUND_EMAIL_SECRET="nxs_email_wh_xxxxxxxxxxxxxxxx"

# ─── Agent / AI Proxy ────────────────────────────────────────
AGENT_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AGENT_API_URL="https://your-agents-service.up.railway.app"
AGENT_EMAIL="sales@yourdomain.com"

# ─── Cloudinary (backend only — never expose to frontend) ────
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ─── Payment ─────────────────────────────────────────────────
ACTIVE_PAYMENT_PROVIDER="stripe"
# STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# ─── Vite passthrough (legacy) ───────────────────────────────
VITE_GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"
