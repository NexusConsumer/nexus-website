# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/nexus?schema=public"
MONGODB_URI="mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="nexus"

# ─── JWT ─────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET="generate-64-char-random-hex"
REFRESH_TOKEN_SECRET="generate-64-char-random-hex"

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="767538589218-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxx"

# ─── WhatsApp Meta Cloud API ─────────────────────────────────
WHATSAPP_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="xxxxxxxxxxxxxxxxx"
WHATSAPP_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_VERIFY_TOKEN="pick-any-random-string"

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Apollo.io ───────────────────────────────────────────────
APOLLO_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Notifications ───────────────────────────────────────────
AGENT_WHATSAPP_NUMBER="+972XXXXXXXXX"   # Your personal WhatsApp number

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@nexus.com"
EMAIL_ASSET_BASE_URL="https://nexus-payment.com"

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL="https://nexus-payment.com"
BACKEND_URL="https://api.nexus-payment.com"
NODE_ENV="development"
PORT=3001

# ─── Payment (add when ready) ────────────────────────────────
ACTIVE_PAYMENT_PROVIDER="stripe"
